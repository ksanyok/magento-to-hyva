<?php
/**
 * FTC Cashmere — Hyvä Product List (Category Page)
 * Replaces ObjectManager with proper ViewModels
 * Replaces inline styles/jQuery with Alpine.js + Tailwind
 * Preserves: color swatches, size indicators, image overlay, CMS banners, badges
 */
declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\ProductListItem;
use Hyva\Theme\ViewModel\ProductPage;
use Hyva\Theme\ViewModel\CurrentCategory;
use Magento\Catalog\Block\Product\ListProduct;
use Magento\Framework\Escaper;

/** @var ListProduct $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

$_productCollection = $block->getLoadedProductCollection();

/** @var ProductPage $productPage */
$productPage = $viewModels->require(ProductPage::class);

/** @var ProductListItem $productListItem */
$productListItem = $viewModels->require(ProductListItem::class);
?>

<?php if (!$_productCollection->count()) : ?>
    <div class="py-12 text-center">
        <p class="text-dark-lighter text-sm">
            <?= $escaper->escapeHtml(__("We can't find products matching the selection.")) ?>
        </p>
    </div>
<?php else : ?>

    <?= /* @noEscape */ $block->getToolbarHtml() ?>

    <div class="products-grid">
        <ol class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
            <?php $i = 0; ?>
            <?php foreach ($_productCollection as $_product) : ?>
                <?php if (!$_product->isSalable()) { continue; } ?>

                <?php
                // CMS banner injection at positions 12 and 24 (matching FTC layout)
                $offset = $_productCollection->getPageSize() * ($_productCollection->getCurPage() - 1);
                $position = $i + $offset;
                ?>

                <?php if ($position === 12) : ?>
                    <?= $block->getChildHtml('category_banner_2') ?>
                <?php endif; ?>

                <?php if ($position === 24) : ?>
                    <?= $block->getChildHtml('category_banner_3') ?>
                <?php endif; ?>

                <li class="product-item group" x-data="{ hovered: false }"
                    @mouseenter="hovered = true" @mouseleave="hovered = false">
                    <div class="relative">
                        <!-- Product Badges -->
                        <div class="absolute top-2 left-2 z-10 flex flex-col gap-1">
                            <?php if ($_product->getNew()) : ?>
                                <span class="bg-dark text-white text-[10px] uppercase tracking-widest px-2 py-0.5">
                                    <?= $escaper->escapeHtml(__('New')) ?>
                                </span>
                            <?php elseif ($_product->getSale()) : ?>
                                <span class="bg-secondary text-white text-[10px] uppercase tracking-widest px-2 py-0.5">
                                    <?= $escaper->escapeHtml(__('Sale')) ?>
                                </span>
                            <?php endif; ?>
                            <?php if ($_product->getUpcycled()) : ?>
                                <span class="bg-accent text-white text-[10px] uppercase tracking-widest px-2 py-0.5">
                                    <?= $escaper->escapeHtml(__('Upcycled')) ?>
                                </span>
                            <?php endif; ?>
                        </div>

                        <!-- Product Image -->
                        <a href="<?= $escaper->escapeUrl($_product->getProductUrl()) ?>"
                           class="block relative overflow-hidden aspect-[3/4] bg-container-lighter">
                            <?php
                            $productImage = $block->getImage($_product, 'category_page_grid');
                            ?>
                            <img src="<?= $escaper->escapeUrl($productImage->getImageUrl()) ?>"
                                 alt="<?= $escaper->escapeHtmlAttr($productImage->getLabel()) ?>"
                                 class="w-full h-full object-cover"
                                 width="<?= $escaper->escapeHtmlAttr($productImage->getWidth()) ?>"
                                 height="<?= $escaper->escapeHtmlAttr($productImage->getHeight()) ?>"
                                 loading="lazy"/>
                            <!-- Hover overlay image (second gallery image) -->
                            <?php
                            $hoverImage = $productListItem->getSecondImage($_product, 'category_page_grid');
                            ?>
                            <?php if ($hoverImage) : ?>
                                <img src="<?= $escaper->escapeUrl($hoverImage->getImageUrl()) ?>"
                                     alt="<?= $escaper->escapeHtmlAttr($hoverImage->getLabel()) ?>"
                                     class="absolute inset-0 w-full h-full object-cover
                                            opacity-0 group-hover:opacity-100 transition-opacity duration-DEFAULT"
                                     loading="lazy"/>
                            <?php endif; ?>
                        </a>

                        <!-- Wishlist Button -->
                        <?php if ($this->helper(\Magento\Wishlist\Helper\Data::class)->isAllow()) : ?>
                            <button type="button"
                                    class="absolute top-2 right-2 z-10 w-8 h-8
                                           flex items-center justify-center
                                           text-dark-lighter hover:text-secondary
                                           transition-colors cursor-pointer"
                                    aria-label="<?= $escaper->escapeHtmlAttr(__('Add to Wish List')) ?>"
                                    @click.prevent="
                                        const postData = <?= /* @noEscape */ $block->getAddToWishlistParams($_product) ?>;
                                        if (postData && postData.action) {
                                            const form = document.createElement('form');
                                            form.method = 'post';
                                            form.action = postData.action;
                                            Object.entries(postData.data || {}).forEach(([key, val]) => {
                                                const input = document.createElement('input');
                                                input.type = 'hidden';
                                                input.name = key;
                                                input.value = val;
                                                form.appendChild(input);
                                            });
                                            document.body.appendChild(form);
                                            form.submit();
                                        }
                                    ">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935
                                             0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1
                                             3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                                </svg>
                            </button>
                        <?php endif; ?>
                    </div>

                    <!-- Product Details -->
                    <div class="mt-3 space-y-1">
                        <h3 class="text-sm">
                            <a href="<?= $escaper->escapeUrl($_product->getProductUrl()) ?>"
                               class="text-dark hover:text-primary transition-colors">
                                <?= $escaper->escapeHtml($_product->getName()) ?>
                            </a>
                        </h3>

                        <?= /* @noEscape */ $block->getProductPrice($_product) ?>

                        <!-- Color Swatches & Available Sizes -->
                        <?php if ($_product->getTypeId() === 'configurable') : ?>
                            <?php
                            $children = $_product->getTypeInstance()->getUsedProducts($_product);
                            $colors = [];
                            $sizes = [];
                            foreach ($children as $child) {
                                if ($child->isSalable()) {
                                    $rgb = $child->getRgbFarbe();
                                    if ($rgb && !in_array($rgb, array_column($colors, 'rgb'))) {
                                        $colors[] = ['rgb' => $rgb];
                                    }
                                    $size = $child->getAttributeText('size');
                                    if ($size && !in_array($size, $sizes)) {
                                        $sizes[] = $size;
                                    }
                                }
                            }

                            $sizeOrder = ['UNI','2XS','XS','S','M','L','XL','2XL','XXL','3XL','4XL','5XL'];
                            usort($sizes, function ($a, $b) use ($sizeOrder) {
                                $posA = array_search(strtoupper($a), $sizeOrder);
                                $posB = array_search(strtoupper($b), $sizeOrder);
                                return ($posA !== false ? $posA : 99) - ($posB !== false ? $posB : 99);
                            });
                            ?>
                            <div class="flex items-center gap-3 mt-2">
                                <!-- Color dots -->
                                <?php if (!empty($colors)) : ?>
                                    <div class="flex items-center gap-1">
                                        <?php $shown = 0; ?>
                                        <?php foreach ($colors as $color) : ?>
                                            <?php if ($shown >= 4) break; ?>
                                            <?php
                                            $r = (int)substr($color['rgb'], 0, 3);
                                            $g = (int)substr($color['rgb'], 3, 3);
                                            $b = (int)substr($color['rgb'], 6, 3);
                                            ?>
                                            <span class="w-3 h-3 rounded-full border border-container"
                                                  style="background-color: rgb(<?= (int)$r ?>, <?= (int)$g ?>, <?= (int)$b ?>);"
                                                  title="<?= $escaper->escapeHtmlAttr($color['rgb']) ?>"></span>
                                            <?php $shown++; ?>
                                        <?php endforeach; ?>
                                        <?php if (count($colors) > 4) : ?>
                                            <span class="text-[10px] text-dark-lighter ml-1">
                                                +<?= (int)(count($colors) - 4) ?>
                                            </span>
                                        <?php endif; ?>
                                    </div>
                                <?php endif; ?>

                                <!-- Available sizes -->
                                <?php if (!empty($sizes)) : ?>
                                    <div class="flex items-center gap-1">
                                        <?php foreach ($sizes as $size) : ?>
                                            <span class="text-[10px] text-dark-lighter uppercase"><?= $escaper->escapeHtml($size) ?></span>
                                        <?php endforeach; ?>
                                    </div>
                                <?php endif; ?>
                            </div>
                        <?php endif; ?>
                    </div>
                </li>
                <?php $i++; ?>
            <?php endforeach; ?>
        </ol>
    </div>

    <?= $block->getChildHtml('toolbar_bottom') ?>

<?php endif; ?>
