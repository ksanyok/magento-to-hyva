<?php
/**
 * FTC Cashmere — Hyvä Product Widget Grid (CMS Blocks)
 * Replaces jQuery slider + modals with Alpine.js
 * Preserves: badge display, color swatches, size indicators, hover images
 */
declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\ProductListItem;
use Magento\CatalogWidget\Block\Product\ProductsList;
use Magento\Framework\Escaper;

/** @var ProductsList $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var ProductListItem $productListItem */
$productListItem = $viewModels->require(ProductListItem::class);

$items = $block->getProductCollection();
$title = $block->getTitle();
?>

<?php if ($items && $items->getSize()) : ?>
<section class="my-12">
    <?php if ($title) : ?>
        <h2 class="text-lg font-semibold uppercase tracking-wider mb-6 text-center">
            <?= $escaper->escapeHtml($title) ?>
        </h2>
    <?php endif; ?>

    <div class="relative" x-data="initWidgetSlider()">
        <div class="overflow-x-auto scrollbar-hide snap-x snap-mandatory scroll-smooth"
             x-ref="slider">
            <div class="flex gap-4 md:gap-6">
                <?php foreach ($items as $_product) : ?>
                    <div class="flex-shrink-0 w-[45%] sm:w-[30%] md:w-[23%] snap-start group">
                        <div class="relative">
                            <!-- Badges -->
                            <div class="absolute top-2 left-2 z-10 flex flex-col gap-1">
                                <?php if ($_product->getNew()) : ?>
                                    <span class="bg-dark text-white text-[10px] uppercase tracking-widest px-2 py-0.5">
                                        <?= $escaper->escapeHtml(__('New')) ?>
                                    </span>
                                <?php elseif ($_product->getSale()) : ?>
                                    <span class="bg-secondary text-white text-[10px] uppercase tracking-widest px-2 py-0.5">
                                        <?= $escaper->escapeHtml(__('Sale')) ?>
                                    </span>
                                <?php endif; ?>
                                <?php if ($_product->getUpcycled()) : ?>
                                    <span class="bg-accent text-white text-[10px] uppercase tracking-widest px-2 py-0.5">
                                        <?= $escaper->escapeHtml(__('Upcycled')) ?>
                                    </span>
                                <?php endif; ?>
                            </div>

                            <!-- Product Image -->
                            <a href="<?= $escaper->escapeUrl($_product->getProductUrl()) ?>"
                               class="block relative overflow-hidden aspect-[3/4] bg-container-lighter">
                                <?php $productImage = $block->getImage($_product, 'category_page_grid'); ?>
                                <img src="<?= $escaper->escapeUrl($productImage->getImageUrl()) ?>"
                                     alt="<?= $escaper->escapeHtmlAttr($productImage->getLabel()) ?>"
                                     class="w-full h-full object-cover"
                                     loading="lazy"/>
                            </a>
                        </div>

                        <!-- Product Info -->
                        <div class="mt-3 space-y-1">
                            <h3 class="text-sm">
                                <a href="<?= $escaper->escapeUrl($_product->getProductUrl()) ?>"
                                   class="text-dark hover:text-primary transition-colors">
                                    <?= $escaper->escapeHtml($_product->getName()) ?>
                                </a>
                            </h3>
                            <?= /* @noEscape */ $block->getProductPriceHtml($_product) ?>

                            <!-- Color Swatches for configurable products -->
                            <?php if ($_product->getTypeId() === 'configurable') : ?>
                                <?php
                                $children = $_product->getTypeInstance()->getUsedProducts($_product);
                                $colors = [];
                                foreach ($children as $child) {
                                    if ($child->isSalable()) {
                                        $rgb = $child->getRgbFarbe();
                                        if ($rgb && !in_array($rgb, array_column($colors, 'rgb'))) {
                                            $colors[] = ['rgb' => $rgb];
                                        }
                                    }
                                }
                                ?>
                                <?php if (!empty($colors)) : ?>
                                    <div class="flex items-center gap-1 mt-1">
                                        <?php $shown = 0; ?>
                                        <?php foreach ($colors as $color) : ?>
                                            <?php if ($shown >= 4) break; ?>
                                            <?php
                                            $r = (int)substr($color['rgb'], 0, 3);
                                            $g = (int)substr($color['rgb'], 3, 3);
                                            $b = (int)substr($color['rgb'], 6, 3);
                                            ?>
                                            <span class="w-3 h-3 rounded-full border border-container"
                                                  style="background-color: rgb(<?= (int)$r ?>, <?= (int)$g ?>, <?= (int)$b ?>);"></span>
                                            <?php $shown++; ?>
                                        <?php endforeach; ?>
                                        <?php if (count($colors) > 4) : ?>
                                            <span class="text-[10px] text-dark-lighter">+<?= (int)(count($colors) - 4) ?></span>
                                        <?php endif; ?>
                                    </div>
                                <?php endif; ?>
                            <?php endif; ?>
                        </div>
                    </div>
                <?php endforeach; ?>
            </div>
        </div>

        <!-- Slider Navigation -->
        <button @click="$refs.slider.scrollBy({left: -$refs.slider.offsetWidth * 0.75, behavior: 'smooth'})"
                class="absolute left-0 top-1/3 -translate-y-1/2 -translate-x-3
                       w-10 h-10 flex items-center justify-center
                       bg-white border border-container text-dark
                       hover:bg-dark hover:text-white transition-colors
                       cursor-pointer hidden md:flex"
                aria-label="<?= $escaper->escapeHtmlAttr(__('Previous')) ?>">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
        </button>
        <button @click="$refs.slider.scrollBy({left: $refs.slider.offsetWidth * 0.75, behavior: 'smooth'})"
                class="absolute right-0 top-1/3 -translate-y-1/2 translate-x-3
                       w-10 h-10 flex items-center justify-center
                       bg-white border border-container text-dark
                       hover:bg-dark hover:text-white transition-colors
                       cursor-pointer hidden md:flex"
                aria-label="<?= $escaper->escapeHtmlAttr(__('Next')) ?>">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
        </button>
    </div>
</section>

<script>
    function initWidgetSlider() {
        return {};
    }
</script>
<?php endif; ?>
