<div class="max-w-2xl mx-auto py-8 px-4"
     x-data="{
        loading: false,
        showPassword: false,
        showConfirmPassword: false,
        showAddressFields: <?= $block->getShowAddressFields() ? 'true' : 'false' ?>,
        password: '',

        get passwordStrength() {
            const p = this.password;
            if (!p) return { label: '', width: '0%', color: 'bg-container' };
            let score = 0;
            if (p.length >= 8) score++;
            if (p.length >= 12) score++;
            if (/[a-z]/.test(p) && /[A-Z]/.test(p)) score++;
            if (/\d/.test(p)) score++;
            if (/[^a-zA-Z0-9]/.test(p)) score++;
            const levels = [
                { label: '<?= $escaper->escapeJs(__('Weak')) ?>', width: '20%', color: 'bg-secondary' },
                { label: '<?= $escaper->escapeJs(__('Fair')) ?>', width: '40%', color: 'bg-secondary' },
                { label: '<?= $escaper->escapeJs(__('Good')) ?>', width: '60%', color: 'bg-primary' },
                { label: '<?= $escaper->escapeJs(__('Strong')) ?>', width: '80%', color: 'bg-accent' },
                { label: '<?= $escaper->escapeJs(__('Very Strong')) ?>', width: '100%', color: 'bg-accent' },
            ];
            return levels[Math.min(score, 4)];
        }
     }">

