<?php
/**
 * FTC Cashmere — Hyvä Customer Account Edit Form
 * Replaces mage/validation + changeEmailPassword widget with Alpine.js
 * Replaces jQuery password strength with Alpine.js
 */
declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Magento\Customer\Block\Form\Edit;
use Magento\Framework\Escaper;

/** @var Edit $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

$customer = $block->getCustomer();
?>

<div class="max-w-2xl mx-auto py-8 px-4"
     x-data="{
        loading: false,
        changeEmail: false,
        changePassword: <?= $block->getChangePassword() ? 'true' : 'false' ?>,
        showCurrentPassword: false,
        showNewPassword: false,
        showConfirmPassword: false,
        newPassword: '',

        get showCredentials() {
            return this.changeEmail || this.changePassword;
        },

        get legendText() {
            if (this.changeEmail && this.changePassword) {
                return '<?= $escaper->escapeJs(__('Change Email and Password')) ?>';
            }
            if (this.changeEmail) {
                return '<?= $escaper->escapeJs(__('Change Email')) ?>';
            }
            return '<?= $escaper->escapeJs(__('Change Password')) ?>';
        },

        get passwordStrength() {
            const p = this.newPassword;
            if (!p) return { label: '<?= $escaper->escapeJs(__('No Password')) ?>', width: '0%', color: 'bg-container' };
            let score = 0;
            if (p.length >= <?= (int) $block->getMinimumPasswordLength() ?>) score++;
            if (p.length >= 12) score++;
            if (/[a-z]/.test(p) && /[A-Z]/.test(p)) score++;
            if (/\d/.test(p)) score++;
            if (/[^a-zA-Z0-9]/.test(p)) score++;
            const levels = [
                { label: '<?= $escaper->escapeJs(__('Weak')) ?>', width: '20%', color: 'bg-secondary' },
                { label: '<?= $escaper->escapeJs(__('Fair')) ?>', width: '40%', color: 'bg-secondary' },
                { label: '<?= $escaper->escapeJs(__('Good')) ?>', width: '60%', color: 'bg-primary' },
                { label: '<?= $escaper->escapeJs(__('Strong')) ?>', width: '80%', color: 'bg-accent' },
                { label: '<?= $escaper->escapeJs(__('Very Strong')) ?>', width: '100%', color: 'bg-accent' },
            ];
            return levels[Math.min(score, 4)];
        }
     }">

    <h1 class="text-2xl font-semibold uppercase tracking-wider mb-8 text-center">
        <?= $escaper->escapeHtml(__('Edit Account Information')) ?>
    </h1>

    <form action="<?= $escaper->escapeUrl($block->getUrl('customer/account/editPost')) ?>"
          method="post"
          id="form-validate"
          enctype="multipart/form-data"
          @submit="loading = true"
          autocomplete="off">
        <?= $block->getBlockHtml('formkey') ?>

        <!-- Account Information -->
        <fieldset class="mb-8">
            <h2 class="text-sm font-semibold uppercase tracking-wider mb-4 pb-2 border-b border-container">
                <?= $escaper->escapeHtml(__('Account Information')) ?>
            </h2>
            <div class="space-y-4">

                <!-- Name widget -->
                <?= $block->getLayout()
                    ->createBlock(\Magento\Customer\Block\Widget\Name::class)
