<?php
/**
 * FTC Cashmere — Hyvä Minicart
 * Replaces KnockoutJS data-bind + dropdownDialog with Alpine.js
 * Uses Hyvä's built-in cart data via private content
 */
declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Magento\Checkout\Block\Cart\Sidebar;
use Magento\Framework\Escaper;

/** @var Sidebar $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
?>

<div x-data="initMiniCart()"
     @private-content-loaded.window="getCartData($event.detail)"
     @toggle-cart.window="open = !open"
     class="minicart-wrapper relative">

    <!-- Cart Trigger -->
    <button type="button"
            @click="open = !open"
            class="relative inline-flex items-center p-2 text-dark hover:text-primary
                   transition-colors duration-DEFAULT cursor-pointer"
            :aria-expanded="open"
            aria-label="<?= $escaper->escapeHtmlAttr(__('Toggle minicart')) ?>">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263
                     12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0
                     01-1.12-1.243l1.264-12A1.125 1.125 0 015.513
                     7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625
                     10.5a.375.375 0 11-.75 0 .375.375 0 01.75
                     0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
        </svg>
        <!-- Item Count Badge -->
        <span x-show="itemCount > 0"
              x-cloak
              x-text="itemCount"
              x-transition
              class="absolute -top-1 -right-1 min-w-[20px] h-5
                     flex items-center justify-center
                     bg-dark text-white text-xs leading-none px-1">
        </span>
    </button>

    <!-- Cart Dropdown -->
    <div x-show="open"
         x-cloak
         x-transition:enter="transition ease-out duration-DEFAULT"
         x-transition:enter-start="opacity-0 translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-fast"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 translate-y-2"
         @click.outside="open = false"
         class="absolute right-0 top-full mt-2 w-80 sm:w-96
                bg-white border border-container shadow-sm z-30">

        <!-- Header -->
        <div class="flex items-center justify-between p-4 border-b border-container">
            <h3 class="text-sm font-semibold uppercase tracking-wider">
                <?= $escaper->escapeHtml(__('My Cart')) ?>
            </h3>
            <button @click="open = false"
                    type="button"
                    class="text-dark-lighter hover:text-dark transition-colors cursor-pointer"
                    aria-label="<?= $escaper->escapeHtmlAttr(__('Close minicart')) ?>">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <!-- Empty State -->
        <template x-if="itemCount === 0">
            <div class="p-8 text-center">
                <p class="text-dark-lighter text-sm">
                    <?= $escaper->escapeHtml(__('You have no items in your shopping cart.')) ?>
                </p>
            </div>
        </template>

        <!-- Cart Items -->
        <template x-if="itemCount > 0">
            <div>
                <div class="max-h-80 overflow-y-auto divide-y divide-container">
                    <template x-for="item in cartItems" :key="item.item_id">
                        <div class="flex gap-3 p-4">
                            <!-- Item Image -->
                            <a :href="item.product_url" class="flex-shrink-0 w-16 h-20">
                                <img :src="item.product_image?.src"
                                     :alt="item.product_name"
                                     class="w-full h-full object-cover"
                                     loading="lazy"/>
                            </a>
                            <!-- Item Details -->
                            <div class="flex-1 min-w-0">
                                <a :href="item.product_url"
                                   class="text-sm text-dark hover:text-primary transition-colors
                                          line-clamp-2 block"
                                   x-text="item.product_name"></a>
                                <!-- Options -->
                                <template x-if="item.options && item.options.length">
                                    <div class="mt-1 space-y-0.5">
                                        <template x-for="option in item.options" :key="option.label">
                                            <p class="text-xs text-dark-lighter">
                                                <span x-text="option.label"></span>:
                                                <span x-text="option.value" class="font-medium"></span>
                                            </p>
                                        </template>
                                    </div>
                                </template>
                                <div class="flex items-center justify-between mt-2">
                                    <span class="text-xs text-dark-lighter"
                                          x-text="'<?= $escaper->escapeJs(__('Qty')) ?>: ' + item.qty"></span>
                                    <span class="text-sm font-medium" x-html="item.product_price"></span>
                                </div>
                            </div>
                        </div>
                    </template>
                </div>

                <!-- Subtotal -->
                <div class="border-t border-container p-4">
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-sm font-semibold uppercase tracking-wider">
                            <?= $escaper->escapeHtml(__('Cart Subtotal')) ?>
                        </span>
                        <span class="text-base font-semibold" x-html="subtotalAmount"></span>
                    </div>

                    <!-- Action Buttons -->
                    <div class="space-y-2">
                        <a href="<?= $escaper->escapeUrl($block->getUrl('checkout')) ?>"
                           class="btn-primary block w-full py-3 text-center">
                            <?= $escaper->escapeHtml(__('Proceed to Checkout')) ?>
                        </a>
                        <a href="<?= $escaper->escapeUrl($block->getShoppingCartUrl()) ?>"
                           class="block w-full py-3 text-center text-sm text-dark
                                  border border-dark hover:bg-dark hover:text-white
                                  uppercase tracking-wider transition-colors duration-DEFAULT">
                            <?= $escaper->escapeHtml(__('View Cart')) ?>
                        </a>
                    </div>
                </div>
            </div>
        </template>
    </div>
</div>

<script>
    function initMiniCart() {
        return {
            open: false,
            cartItems: [],
            itemCount: 0,
            subtotalAmount: '',

            getCartData(data) {
                if (data && data.cart) {
                    this.itemCount = parseInt(data.cart.summary_count) || 0;
                    this.cartItems = data.cart.items || [];
                    this.subtotalAmount = data.cart.subtotalAmount || '';
                }
            }
        };
    }
</script>
