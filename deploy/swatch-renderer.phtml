$tooltipBlockHtml = $block->getBlockHtml('product.swatch.tooltip');
?>
<?php if (count($attributes)): ?>
    <script>
        function initConfigurableSwatchOptions_<?= (int) $productId ?>() {
            const configurableOptionsComponent = initConfigurableOptions(
                '<?= (int) $productId ?>',
                <?= /* @noEscape */ $block->getJsonConfig() ?>
            );
            const swatchOptionsComponent = initSwatchOptions(
                <?= /* @noEscape */ $block->getJsonSwatchConfig() ?>
            );

            const merged = Object.assign(
                configurableOptionsComponent,
                swatchOptionsComponent
            );

            // Add method to get product image for a swatch option
            // Uses the last gallery image (typically the flat/product group shot "pfg")
            // to match the original site behavior
            merged.getSwatchProductImage = function(attributeId, optionId) {
                const attrs = this.optionConfig && this.optionConfig.attributes;
                if (!attrs || !attrs[attributeId]) return '';
                const option = attrs[attributeId].options.find(o => o.id === optionId);
                if (!option || !option.products || !option.products.length) return '';
                const productId = option.products[0];
                const images = this.optionConfig.images && this.optionConfig.images[productId];
                if (!images || !images.length) return '';
                // Use the last image (highest position = flat/product group shot)
                const lastImg = images[images.length - 1];
                return lastImg.thumb || lastImg.img || '';
            };

            // Match original behavior: keep color swatches in a single row and
            // render a trailing +N tile that expands all remaining options.
            // Match Luma behavior: 5 visible color tiles, the 6th tile is "+N".
            merged.swatchCollapsedCount = 5;
            merged.expandedSwatches = {};

            merged.getAttributeOptions = function(attributeId) {
                const attrs = this.optionConfig && this.optionConfig.attributes
                    ? this.optionConfig.attributes
                    : null;
                const attr = attrs && attrs[attributeId] ? attrs[attributeId] : null;
                return attr && Array.isArray(attr.options) ? attr.options : [];
            };

            merged.isExpandableColorAttribute = function(attributeId) {
                const attrs = this.optionConfig && this.optionConfig.attributes
                    ? this.optionConfig.attributes
                    : null;
                const attr = attrs && attrs[attributeId] ? attrs[attributeId] : null;
                if (!attr || !attr.code) return false;
                const code = String(attr.code).toLowerCase();
                return code === 'color' || code === 'color_name';
            };

            merged.isSwatchExpanded = function(attributeId) {
                return !!this.expandedSwatches[String(attributeId)];
            };

            merged.hasCollapsedSwatches = function(attributeId) {
                if (!this.isExpandableColorAttribute(attributeId)) {
                    return false;
                }
                return this.getAttributeOptions(attributeId).length > this.swatchCollapsedCount;
            };

            merged.hiddenSwatchCount = function(attributeId) {
                const hidden = this.getAttributeOptions(attributeId).length - this.swatchCollapsedCount;
                return hidden > 0 ? hidden : 0;
            };

            merged.getCollapsedVisibleOptionIds = function(attributeId) {
                const options = this.getAttributeOptions(attributeId);
                const visibleIds = [];
                const visibleSet = {};

                // Prefer first enabled options so the first row is never empty.
                for (let i = 0; i < options.length; i++) {
                    const id = options[i].id;
                    if (this.optionIsEnabled(attributeId, id)) {
                        visibleIds.push(id);
                        visibleSet[String(id)] = true;
                        if (visibleIds.length >= this.swatchCollapsedCount) {
                            return visibleIds;
                        }
                    }
                }

                // Fallback: if enabled options are fewer, fill with remaining options.
                for (let i = 0; i < options.length && visibleIds.length < this.swatchCollapsedCount; i++) {
                    const id = options[i].id;
                    if (!visibleSet[String(id)]) {
                        visibleIds.push(id);
                        visibleSet[String(id)] = true;
                    }
                }

                return visibleIds;
            };

            merged.isSwatchOptionVisible = function(attributeId, optionId) {
                if (!this.hasCollapsedSwatches(attributeId) || this.isSwatchExpanded(attributeId)) {
                    return true;
                }

                return this.getCollapsedVisibleOptionIds(attributeId).includes(optionId);
            };

            merged.expandSwatches = function(attributeId) {
                this.expandedSwatches[String(attributeId)] = true;
            };

            // Auto-select first visual swatch attribute (color/image) when nothing is selected.
            // This keeps initial gallery/variation state aligned with the original storefront.
            const originalInit = merged.init;
            merged.init = function() {
                originalInit.call(this);

                this.$nextTick(() => {
                    const attrs = this.optionConfig && this.optionConfig.attributes
                        ? Object.values(this.optionConfig.attributes).sort((a, b) => a.position - b.position)
                        : [];

                    for (const attr of attrs) {
                        const allowed = this.getAllowedAttributeOptions
                            ? this.getAllowedAttributeOptions(attr.id)
                            : (attr.options || []);

                        if (!allowed || !allowed.length || this.selectedValues[attr.id]) {
                            continue;
                        }

                        const firstOptionId = allowed[0].id;
                        const swatchType = this.getSwatchType
                            ? this.getSwatchType(attr.id, firstOptionId)
                            : null;

                        const isSwatch = swatchType !== null && typeof swatchType !== 'undefined';
                        if (isSwatch) {
                            this.changeOption(attr.id, firstOptionId);
                            break;
                        }
                    }
                });
            };

            return merged;
        }
    </script>

    <div x-data="initConfigurableSwatchOptions_<?= (int) $productId ?>()"
         @private-content-loaded.window="onGetCartData($event.detail.data)"
