<?php
/**
 * Hyvä Theme — FTC Cashmere Header
 * Layout: Centered logo, navigation overlapping below, icons right
 * Matches production: shop.ftc-cashmere.com
 */
declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HyvaCsp;
use Hyva\Theme\ViewModel\StoreConfig;
use Magento\Checkout\Block\Cart\Sidebar as SidebarCart;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var ViewModelRegistry $viewModels */
/** @var HyvaCsp $hyvaCsp */

$storeConfig = $viewModels->require(StoreConfig::class);
$showMiniCart = $storeConfig->getStoreConfig(SidebarCart::XML_PATH_CHECKOUT_SIDEBAR_DISPLAY);

$storeName = 'DE';
$currencyCode = 'EUR';
$storeCode = 'de-de';
try {
    $objectManager = \Magento\Framework\App\ObjectManager::getInstance();
    $storeManagerObj = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
    $currentStore = $storeManagerObj->getStore();
    $storeName = strtoupper(substr((string)$currentStore->getCode(), 0, 2));
    $currencyCode = (string)$currentStore->getCurrentCurrencyCode();
    $storeCode = (string)$currentStore->getCode();
} catch (\Exception $e) {}

// Build store redirect URLs for region chooser
$storeRedirectUrls = [];
try {
    $currentUrl = $storeManagerObj->getStore()->getCurrentUrl(false);
    $stores = $storeManagerObj->getStores();
    foreach ($stores as $store) {
        if (!$store->getIsActive()) {
            continue;
        }
        $sc = (string)$store->getCode();
        $targetUrl = $store->getBaseUrl() . 'stores/store/redirect/___store/'
            . $sc . '/___from_store/' . $storeCode . '/uenc/'
            . strtr(base64_encode($currentUrl), '+/=', '-_,') . '/';
        $storeRedirectUrls[$sc] = $targetUrl;
    }
} catch (\Exception $e) {}

$gwlItemCount = 0;
try {
    $gwlHelper = $this->helper(\Magestall\GuestWishlist\Helper\Data::class);
    $gwlItemCount = (int)$gwlHelper->getItemCount();
} catch (\Exception $e) {}

$iconUrl = $block->getViewFileUrl('images/icons');

// Announcement bar CMS block
$promotionHtml = '';
try {
    $promotionBlock = $block->getLayout()
        ->createBlock(\Magento\Cms\Block\Block::class)
        ->setBlockId('promotion_header');
    $promotionHtml = trim((string)$promotionBlock->toHtml());
} catch (\Exception $e) {}

// Country configuration for region chooser
$countries = [
    ['code' => 'dk', 'name' => 'Denmark'],
    ['code' => 'de', 'name' => 'Germany (DE)'],
    ['code' => 'nl', 'name' => 'Netherlands'],
    ['code' => 'at', 'name' => 'Austria'],
    ['code' => 'pl', 'name' => 'Poland'],
    ['code' => 'se', 'name' => 'Sweden'],
    ['code' => 'ch', 'name' => 'Switzerland'],
    ['code' => 'be', 'name' => 'Belgium'],
    ['code' => 'it', 'name' => 'Italy'],
    ['code' => 'fr', 'name' => 'France'],
];
?>
<script>
    function initHeader() {
        return {
            searchOpen: false,
            cart: {},
            isCartOpen: false,
            mobileMenuOpen: false,
            announcementDismissed: false,
            slideIndex: 0,
            slideTimer: null,
            regionChooserOpen: false,
            selectedCountry: '<?= $escaper->escapeJs(substr($storeCode, 3, 2)) ?>',
            selectedLanguage: '<?= $escaper->escapeJs(substr($storeCode, 0, 2)) ?>',
            storeUrls: <?= /** @noEscape */ json_encode($storeRedirectUrls) ?>,
            getData(data) { this.cart = data.cart ?? {}; },
            summaryCount() { return this.cart.summary_count || 0; },
            cartAriaLabel() {
                return '<?= $escaper->escapeJs($showMiniCart ? __('Toggle minicart') : __('View cart')) ?>, ' +
                    (this.isCartEmpty() ? '<?= $escaper->escapeJs(__('Cart is empty')) ?>' : (
                        Math.abs(this.summaryCount()) > 1
                            ? hyva.str('<?= $escaper->escapeJs(__('%1 items')) ?>', this.summaryCount())
                            : hyva.str('<?= $escaper->escapeJs(__('%1 item')) ?>', this.summaryCount())
                    ))
            },
            isCartEmpty() { return !this.cart.summary_count; },
            toggleCart() {
                this.isCartOpen = this.$event.detail?.isOpen ?? true;
                this.$dispatch('toggle-cart', { isOpen: this.isCartOpen })
            },
            toggleSearch() {
                this.searchOpen = !this.searchOpen;
                if (this.searchOpen) this.$dispatch('search-open');
            },
            searchClose() { this.searchOpen = false; },
            searchShortcut(e) {
                const mod = /Mac|iPod|iPhone|iPad/.test(navigator.platform) ? e.metaKey : e.ctrlKey;
                if (mod && e.key === 'k') { e.preventDefault(); this.searchOpen = true; this.$dispatch('search-open'); }
            },
            dismissAnnouncement() {
                this.announcementDismissed = true;
                if (this.slideTimer) clearInterval(this.slideTimer);
            },
            initSlides() {
                const slides = this.$el.querySelectorAll('.home-message p.slide');
                if (slides.length < 2) return;
                slides.forEach((s, i) => {
                    s.style.position = 'absolute';
                    s.style.left = '0';
                    s.style.right = '0';
                    s.style.transition = 'opacity 2s';
                    s.style.opacity = i === 0 ? '1' : '0';
                });
                this.$el.querySelector('.home-message').style.position = 'relative';
                this.slideTimer = setInterval(() => {
                    const sl = this.$el.querySelectorAll('.home-message p.slide');
                    if (!sl.length) return;
                    const cur = this.slideIndex;
                    const next = (cur + 1) % sl.length;
                    sl[cur].style.opacity = '0';
                    sl[next].style.opacity = '1';
                    this.slideIndex = next;
                }, 7000);
            },
            openRegionChooser() {
                this.regionChooserOpen = true;
            },
            closeRegionChooser() {
                this.regionChooserOpen = false;
            },
            selectCountry(code) {
                this.selectedCountry = code;
                const availableLangs = this.getAvailableLanguages();
                if (!availableLangs.includes(this.selectedLanguage)) {
                    this.selectedLanguage = availableLangs[0] || 'en';
                }
            },
            getAvailableLanguages() {
                const langs = [];
                const urls = this.storeUrls;
                for (const key in urls) {
                    if (key.endsWith('-' + this.selectedCountry)) {
                        langs.push(key.substring(0, 2));
                    }
                }
                return langs;
            },
            applyRegion() {
                const storeCode = this.selectedLanguage + '-' + this.selectedCountry;
                const url = this.storeUrls[storeCode];
                if (url) {
                    window.location.href = url;
                }
            }
        }
    }
    window.addEventListener('alpine:init', () => { Alpine.data('initHeader', initHeader); }, { once: true })
</script>
<?php $hyvaCsp->registerInlineScript() ?>

